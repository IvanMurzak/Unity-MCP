<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="extension-item" class="row" style="align-items: center; margin-top: 2px; margin-bottom: 2px;">
        <ui:Label name="extension-name" text="Extension Name" class="section-title" style="flex-shrink: 0; margin-bottom: 0;" />
        <ui:Label name="extension-desc" text="Extension description." class="section-desc" style="flex-grow: 1; flex-shrink: 1; margin-bottom: 0; margin-left: 6px;" />
        <ui:Button name="extension-install-btn" text="Install" class="btn-compact btn-secondary" />
    </ui:VisualElement>
</ui:UXML>
